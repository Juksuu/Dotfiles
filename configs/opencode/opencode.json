{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "opencode-plugin-llama.cpp@latest"
    ],
    "permission": {
        "*": "ask",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "lsp": "allow",
    },
    "provider": {
        "llama.cpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama.cpp (local)",
            "options": {
                "baseURL": "http://127.0.0.1:42069/v1"
            }
        }
    }
}
